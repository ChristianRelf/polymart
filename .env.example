# Polymart homeserver environment variables
# Copy this file to .env and fill in your values

# Node API server port
PORT=4000

# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=polymart
DB_PASSWORD=change_me_strong_password
DB_NAME=polymart

# ── Clerk (Authentication) ─────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Webhook secret - create a webhook in Clerk dashboard pointing to /api/v1/account/webhook
CLERK_WEBHOOK_SECRET=whsec_...

# ── Stripe (Billing) ───────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret - create a webhook in Stripe dashboard pointing to /api/v1/webhooks/stripe
# Events to enable: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...
# Monthly Premium price ID - create a product in Stripe dashboard and copy the price ID
STRIPE_PREMIUM_PRICE_ID=price_...
# Optional: only needed if using Stripe.js client-side (not currently required)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── App URLs ───────────────────────────────────────────────────────────────────
# The public URL of the frontend app (used for Stripe success/cancel redirect URLs)
APP_URL=http://localhost:5173
# Comma-separated list of allowed origins for authenticated API routes (restrictive CORS)
# In production: https://polymart.co
ALLOWED_ORIGINS=http://localhost:5173

# ── Discord Bot ───────────────────────────────────────────────────────────────
# Pre-shared secret used by the Polymart Discord bot to authenticate against /api/v1/bot/*
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This same value goes in the Discord bot's .env as BOT_API_KEY=
BOT_API_KEY=

# ── Support / Email ────────────────────────────────────────────────────────────
# Email address that receives support ticket notifications
SUPPORT_EMAIL=support@polymart.co
# Resend API key - get from https://resend.com/api-keys
# Leave blank to disable email sending (tickets will still be stored in the DB)
RESEND_API_KEY=re_...
